-- **C. Copy Button Click**
CopyButton.MouseButton1Click:Connect(function()
    if currentAccessCode ~= "Not Generated" and setclipboard then
        setclipboard(currentAccessCode)
        CopyButton.Text = "Copied!"
        StatusLabel.Text = "Status: Access Code Copied to Clipboard!"
        StatusLabel.TextColor3 = Color3.new(0, 1, 0) -- Green
        wait(1)
        CopyButton.Text = "Copy"
    else
        CopyButton.Text = "Failed"
        StatusLabel.Text = "Status: ERROR - Failed to Copy!"
        StatusLabel.TextColor3 = Color3.new(1, 0, 0) -- Red
        wait(1)
        CopyButton.Text = "Copy"
    end
end)

